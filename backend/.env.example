# Use sqlite by default for quick local prototype validation.
# Set DB_ENGINE=mysql and fill the values below to use MySQL.
DEBUG=true
SECRET_KEY=replace-me-in-production
ALLOWED_HOSTS=127.0.0.1,localhost,your-backend-domain.com
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,https://your-vercel-domain.vercel.app
CSRF_TRUSTED_ORIGINS=https://your-vercel-domain.vercel.app

DB_ENGINE=sqlite
DB_NAME=solarpulse
DB_USER=root
DB_PASSWORD=
DB_HOST=127.0.0.1
DB_PORT=3306

# Railway MySQL can also be auto-detected from:
# MYSQLHOST / MYSQLPORT / MYSQLUSER / MYSQLPASSWORD / MYSQLDATABASE / MYSQL_URL

# OpenAI-compatible LLM config
LLM_API_KEY=
LLM_API_URL=https://api.deepseek.com/chat/completions
LLM_MODEL=deepseek-chat
LLM_TIMEOUT_SECONDS=45
